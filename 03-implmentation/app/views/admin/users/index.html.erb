<% content_for :title, "Users" %>

<h1>Users</h1>

<p><%= link_to "New user", new_admin_user_path %></p>

<table>
  <thead>
    <tr>
      <th>Email</th>
      <th>Role</th>
      <th>Created</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.email %></td>
        <td><%= user.role %></td>
        <td><%= user.created_at.strftime("%Y-%m-%d") %></td>
        <td>
          <%= link_to "Edit", edit_admin_user_path(user) %>
          <% unless user == current_user %>
            &nbsp;
            <%= button_to "Delete", admin_user_path(user), method: :delete,
                  data: { turbo_confirm: "Delete #{user.email}?" } %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
